VITE_LANGGRAPH_API_URL=http://localhost:2024
VITE_SLIDEV_AGENT_DECK_ID=example-deck

# Optional: override the filesystem root the agent can edit.
# Defaults to the directory where `langgraph dev` is started.
# SLIDEV_AGENT_ROOT_DIR=/absolute/path/to/your/slidev/project

SLIDEV_AGENT_API_URL=http://localhost:2024
SLIDEV_AGENT_DECK_ID=example-deck
SLIDEV_AGENT_DEFAULT_DECK_ID=example-deck
SLIDEV_AGENT_DEFAULT_USER_ID=local-user
SLIDEV_AGENT_ROUTE_PREFIX=/slidev-agent
