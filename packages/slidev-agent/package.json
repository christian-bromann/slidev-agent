    "marked": "^17.0.5",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/google": "^0.1.9",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.4.1",
    "@slidev/cli": "^52.14.1",
    "vue": "^3.5.0"
